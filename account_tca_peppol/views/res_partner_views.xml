<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_tca_peppol" model="ir.ui.view">
        <field name="name">res.partner.form.tca.peppol</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">

            <!-- Rename the existing "Invoicing" tab (account module) to "E-Invoicing" -->
            <xpath expr="//page[@name='accounting']" position="attributes">
                <attribute name="string">E-Invoicing</attribute>
            </xpath>

            <!-- Append UAE-specific groups inside the renamed E-Invoicing tab -->
            <xpath expr="//page[@name='accounting']" position="inside">
                <group>
                    <group string="UAE Legal Registration">
                        <field name="tca_legal_id_type" string="Legal ID Type"/>
                        <field name="tca_trade_license" string="Trade License / Registration ID"/>
                        <field name="tca_legal_authority" string="Issuing Authority"
                               invisible="tca_legal_id_type != 'TL'"/>
                        <field name="tca_passport_country_id" string="Passport Issuing Country"
                               invisible="tca_legal_id_type != 'PAS'"/>
                    </group>
                    <group string="UAE Address">
                        <field name="tca_emirate" string="Emirate"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
