<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Fallback cron: sync outbound invoice status every 15 minutes -->
        <!-- Normal operation: webhooks update status in real-time. -->
        <!-- This cron catches invoices that missed their webhook (server restart, etc.) -->
        <record id="ir_cron_tca_sync_outbound_status" model="ir.cron">
            <field name="name">TCA Peppol: Sync Outbound Invoice Status</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_tca_sync_outbound_status()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

        <!-- Fallback cron: pull unacknowledged inbound invoices every 30 minutes -->
        <!-- Normal operation: DOCUMENT_RECEIVED webhook triggers import. -->
        <!-- This cron handles missed webhook deliveries. -->
        <record id="ir_cron_tca_pull_inbound_invoices" model="ir.cron">
            <field name="name">TCA Peppol: Pull Unacknowledged Inbound Invoices</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_tca_pull_inbound_invoices()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
