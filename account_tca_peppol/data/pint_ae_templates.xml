<?xml version="1.0" encoding="utf-8"?>
<!--
  PINT AE QWeb UBL templates — UAE-specific extensions over BIS3 / UBL 2.1

  Design principle: pass the right data from Python and let parent templates
  render it. Only add xpaths for elements that have NO parent rendering.

  Parent template rendering we leverage (no xpath needed):
    - InvoicePeriod/Description: ubl_20_InvoicePeriod renders vals.get('description')
    - TaxExemptionReasonCode/Reason: ubl_20_TaxCategoryType renders from vals
    - PricingExchangeRate: ubl_20_CommonType renders via pricing_exchange_rate_vals_list
    - AdditionalDocumentReference/DocumentDescription: ubl_20_CommonType renders it
-->
<odoo>

    <!-- ════════════════════════════════════════════════════════════════════════
         PartyType — adds CompanyLegalForm (IBT-033) after CompanyID in PartyLegalEntity.
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_PartyType"
              inherit_id="account_edi_ubl_cii.ubl_20_PartyType"
              primary="True">
        <xpath expr="//*[local-name()='PartyLegalEntity']/*[local-name()='CompanyID']" position="after">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:CompanyLegalForm t-if="foreach_vals.get('company_legal_form')"
                                      t-out="foreach_vals['company_legal_form']"/>
            </t>
        </xpath>
    </template>

    <!-- ════════════════════════════════════════════════════════════════════════
         TaxTotalType — adds TaxIncludedIndicator (IBT-200).
         For BTAE-20 AED totals (btae_20_aed_total=True): indicator is suppressed.
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_TaxTotalType"
              inherit_id="account_edi_ubl_cii.ubl_20_TaxTotalType"
              primary="True">
        <xpath expr="//*[local-name()='TaxAmount']" position="after">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:TaxIncludedIndicator
                    t-if="vals.get('tax_included_indicator') is not None and not vals.get('btae_20_aed_total')"
                    t-out="vals.get('tax_included_indicator', 'false')"/>
            </t>
        </xpath>
    </template>

    <!-- ════════════════════════════════════════════════════════════════════════
         TaxCategoryType — adds PerUnitAmount after TaxExemptionReason.
         Parent ubl_20_TaxCategoryType already renders:
           ID, Name, Percent, TaxExemptionReasonCode, TaxExemptionReason, TierRange, TaxScheme
         We insert PerUnitAmount before TaxScheme (after TaxExemptionReason).
         Variable inside this template is 'vals' (set by t-call).
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_TaxCategoryType"
              inherit_id="account_edi_ubl_cii.ubl_20_TaxCategoryType"
              primary="True">
        <xpath expr="//*[local-name()='TaxScheme']" position="before">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:PerUnitAmount
                    t-if="vals.get('per_unit_amount')"
                    t-att-currencyID="vals.get('per_unit_amount_currency', {}).name if vals.get('per_unit_amount_currency') else ''"
                    t-out="vals['per_unit_amount']"/>
            </t>
        </xpath>
    </template>

    <!-- ════════════════════════════════════════════════════════════════════════
         DeliveryType — adds DeliveryTerms (BTAE-22 Incoterms) after DeliveryParty.
         Variable inside this template is 'vals' (set by t-call from Delivery foreach).
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_DeliveryType"
              inherit_id="account_edi_ubl_cii.ubl_20_DeliveryType"
              primary="True">
        <xpath expr="//*[local-name()='DeliveryParty']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <!-- BTAE-22: DeliveryTerms with Incoterms for exports.
                     Placed after DeliveryParty per UBL 2.1 schema order. -->
                <t t-if="vals.get('delivery_terms_vals')">
                    <cac:DeliveryTerms>
                        <cbc:ID t-att="vals['delivery_terms_vals'].get('id_attrs', {})"
                                t-out="vals['delivery_terms_vals']['id']"/>
                    </cac:DeliveryTerms>
                </t>
            </t>
        </xpath>
    </template>

    <!-- ════════════════════════════════════════════════════════════════════════
         InvoiceLineType — PINT AE line additions.
         Adds: BuyersItemIdentification (IBT-156),
               OrderLineReference (IBT-132),
               AccountingCost (IBT-133),
               Line InvoicePeriod (IBG-26),
               CommodityClassification (BTAE-13/BTAE-09/IBT-158),
               BTAE-24 ItemInstance,
               ItemPriceExtension (BTAE-10/BTAE-08)
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_InvoiceLineType"
              inherit_id="account_edi_ubl_cii.ubl_20_InvoiceLineType"
              primary="True">

        <!-- IBT-133: AccountingCost BEFORE InvoicePeriod per XSD -->
        <xpath expr="//*[local-name()='InvoicePeriod']" position="before">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:AccountingCost t-if="vals.get('accounting_cost')"
                                    t-out="vals['accounting_cost']"/>
            </t>
        </xpath>

        <!-- IBT-132: OrderLineReference AFTER InvoicePeriod per XSD -->
        <xpath expr="//*[local-name()='InvoicePeriod']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:OrderLineReference t-if="vals.get('order_line_ref')">
                    <cbc:LineID t-out="vals['order_line_ref']"/>
                </cac:OrderLineReference>
            </t>
        </xpath>

        <!-- IBT-156: BuyersItemIdentification before SellersItemIdentification -->
        <xpath expr="//*[local-name()='Item']/*[local-name()='SellersItemIdentification']"
               position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:BuyersItemIdentification t-if="item_vals.get('buyers_item_identification_vals')">
                    <cbc:ID t-out="item_vals['buyers_item_identification_vals']['id']"/>
                </cac:BuyersItemIdentification>
            </t>
        </xpath>

        <!-- BTAE-13 / BTAE-09 / IBT-158: CommodityClassification before ClassifiedTaxCategory -->
        <xpath expr="//*[local-name()='Item']/*[local-name()='ClassifiedTaxCategory']"
               position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <t t-foreach="item_vals.get('pint_ae_commodity_classifications', [])"
                   t-as="cc">
                    <cac:CommodityClassification>
                        <cbc:NatureCode t-if="cc.get('nature_code')"
                                        t-out="cc['nature_code']"/>
                        <cbc:CommodityCode t-if="cc.get('commodity_code')"
                                           t-out="cc['commodity_code']"/>
                        <cbc:ItemClassificationCode
                            t-if="cc.get('item_classification_code')"
                            t-att="cc.get('item_classification_code_attrs', {})"
                            t-out="cc['item_classification_code']"/>
                    </cac:CommodityClassification>
                </t>
            </t>
        </xpath>

        <!-- BTAE-17 + BTAE-24 after the last Item child (after ClassifiedTaxCategory) -->
        <xpath expr="//*[local-name()='Item']/*[local-name()='ClassifiedTaxCategory']"
               position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:ItemInstance t-if="item_vals.get('btae_24_lot_number')">
                    <cac:LotIdentification>
                        <cbc:LotNumberID t-out="item_vals['btae_24_lot_number']"/>
                    </cac:LotIdentification>
                </cac:ItemInstance>
            </t>
        </xpath>

        <!-- ibr-126-ae: AllowanceCharge inside Price for GrossPrice/Discount -->
        <xpath expr="//*[local-name()='Price']/*[local-name()='BaseQuantity']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <t t-set="pac" t-value="vals.get('price_vals', {}).get('allowance_charge_vals', {})"/>
                <cac:AllowanceCharge t-if="pac">
                    <cbc:ChargeIndicator t-out="pac.get('charge_indicator', 'false')"/>
                    <cbc:Amount t-att-currencyID="pac['currency'].name"
                                t-out="format_float(pac.get('amount'), pac.get('currency_dp'))"/>
                    <cbc:BaseAmount t-att-currencyID="pac['currency'].name"
                                    t-out="format_float(pac.get('base_amount'), pac.get('currency_dp'))"/>
                </cac:AllowanceCharge>
            </t>
        </xpath>

        <!-- BTAE-10 / BTAE-08: ItemPriceExtension after Price -->
        <xpath expr="//*[local-name()='Price']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <t t-set="ipe" t-value="vals.get('item_price_extension_vals', {})"/>
                <cac:ItemPriceExtension t-if="ipe">
                    <cbc:Amount
                        t-att-currencyID="ipe['currency'].name"
                        t-out="format_float(ipe.get('amount'), ipe.get('currency_dp'))"/>
                    <t t-set="ipe_tax" t-value="ipe.get('tax_total_vals', {})"/>
                    <cac:TaxTotal t-if="ipe_tax">
                        <cbc:TaxAmount
                            t-att-currencyID="ipe_tax['currency'].name"
                            t-out="format_float(ipe_tax.get('tax_amount'), ipe_tax.get('currency_dp'))"/>
                    </cac:TaxTotal>
                </cac:ItemPriceExtension>
            </t>
        </xpath>

    </template>

    <!-- CreditNote lines — inherits ubl_21 (which adds AllowanceCharge) -->
    <template id="pint_ae_CreditNoteLineType"
              inherit_id="account_edi_ubl_cii.ubl_21_CreditNoteLineType"
              primary="True">

        <!-- IBT-133 + IBT-132: AccountingCost + OrderLineReference after LineExtensionAmount -->
        <xpath expr="//*[local-name()='LineExtensionAmount']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:AccountingCost t-if="vals.get('accounting_cost')"
                                    t-out="vals['accounting_cost']"/>
                <cac:InvoicePeriod t-foreach="vals.get('invoice_period_vals_list', [])" t-as="ip">
                    <cbc:StartDate t-if="ip.get('start_date')" t-out="ip['start_date']"/>
                    <cbc:EndDate t-if="ip.get('end_date')" t-out="ip['end_date']"/>
                </cac:InvoicePeriod>
                <cac:OrderLineReference t-if="vals.get('order_line_ref')">
                    <cbc:LineID t-out="vals['order_line_ref']"/>
                </cac:OrderLineReference>
            </t>
        </xpath>

        <!-- IBT-156: BuyersItemIdentification before SellersItemIdentification -->
        <xpath expr="//*[local-name()='Item']/*[local-name()='SellersItemIdentification']"
               position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:BuyersItemIdentification t-if="item_vals.get('buyers_item_identification_vals')">
                    <cbc:ID t-out="item_vals['buyers_item_identification_vals']['id']"/>
                </cac:BuyersItemIdentification>
            </t>
        </xpath>

        <!-- BTAE-13 / BTAE-09 / IBT-158: CommodityClassification -->
        <xpath expr="//*[local-name()='Item']/*[local-name()='ClassifiedTaxCategory']"
               position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <t t-foreach="item_vals.get('pint_ae_commodity_classifications', [])"
                   t-as="cc">
                    <cac:CommodityClassification>
                        <cbc:NatureCode t-if="cc.get('nature_code')"
                                        t-out="cc['nature_code']"/>
                        <cbc:CommodityCode t-if="cc.get('commodity_code')"
                                           t-out="cc['commodity_code']"/>
                        <cbc:ItemClassificationCode
                            t-if="cc.get('item_classification_code')"
                            t-att="cc.get('item_classification_code_attrs', {})"
                            t-out="cc['item_classification_code']"/>
                    </cac:CommodityClassification>
                </t>
            </t>
        </xpath>

        <!-- BTAE-17 + BTAE-24 -->
        <xpath expr="//*[local-name()='Item']/*[local-name()='ClassifiedTaxCategory']"
               position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:ItemInstance t-if="item_vals.get('btae_24_lot_number')">
                    <cac:LotIdentification>
                        <cbc:LotNumberID t-out="item_vals['btae_24_lot_number']"/>
                    </cac:LotIdentification>
                </cac:ItemInstance>
            </t>
        </xpath>

        <!-- ibr-126-ae: AllowanceCharge inside Price for GrossPrice/Discount -->
        <xpath expr="//*[local-name()='Price']/*[local-name()='BaseQuantity']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <t t-set="pac" t-value="vals.get('price_vals', {}).get('allowance_charge_vals', {})"/>
                <cac:AllowanceCharge t-if="pac">
                    <cbc:ChargeIndicator t-out="pac.get('charge_indicator', 'false')"/>
                    <cbc:Amount t-att-currencyID="pac['currency'].name"
                                t-out="format_float(pac.get('amount'), pac.get('currency_dp'))"/>
                    <cbc:BaseAmount t-att-currencyID="pac['currency'].name"
                                    t-out="format_float(pac.get('base_amount'), pac.get('currency_dp'))"/>
                </cac:AllowanceCharge>
            </t>
        </xpath>

        <!-- BTAE-10 / BTAE-08: ItemPriceExtension -->
        <xpath expr="//*[local-name()='Price']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <t t-set="ipe" t-value="vals.get('item_price_extension_vals', {})"/>
                <cac:ItemPriceExtension t-if="ipe">
                    <cbc:Amount
                        t-att-currencyID="ipe['currency'].name"
                        t-out="format_float(ipe.get('amount'), ipe.get('currency_dp'))"/>
                    <t t-set="ipe_tax" t-value="ipe.get('tax_total_vals', {})"/>
                    <cac:TaxTotal t-if="ipe_tax">
                        <cbc:TaxAmount
                            t-att-currencyID="ipe_tax['currency'].name"
                            t-out="format_float(ipe_tax.get('tax_amount'), ipe_tax.get('currency_dp'))"/>
                    </cac:TaxTotal>
                </cac:ItemPriceExtension>
            </t>
        </xpath>

    </template>

    <!-- ════════════════════════════════════════════════════════════════════════
         InvoiceType — UAE root-level elements.
         Parent already renders: InvoicePeriod/Description, PricingExchangeRate,
         AdditionalDocumentReference/DocumentDescription via data-driven vals.
         We only add elements that have NO parent rendering.
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_InvoiceType"
              inherit_id="account_edi_ubl_cii.ubl_21_InvoiceType"
              primary="True">

        <!-- BTAE-02: ProfileExecutionID after ProfileID -->
        <xpath expr="//*[local-name()='ProfileID']" position="after">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:ProfileExecutionID t-if="vals.get('profile_execution_id')"
                                        t-out="vals['profile_execution_id']"/>
            </t>
        </xpath>

        <!-- IssueTime (IBT-168) after IssueDate -->
        <xpath expr="//*[local-name()='IssueDate']" position="after">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:IssueTime t-if="vals.get('issue_time')"
                               t-out="vals['issue_time']"/>
            </t>
        </xpath>

        <!-- IBT-007: TaxPointDate after Note, before DocumentCurrencyCode -->
        <xpath expr="//*[local-name()='DocumentCurrencyCode']" position="before">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:TaxPointDate t-if="vals.get('tax_point_date')"
                                  t-out="vals['tax_point_date']"/>
            </t>
        </xpath>

        <!-- IBT-019: AccountingCost before BuyerReference -->
        <xpath expr="//*[local-name()='BuyerReference']" position="before">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:AccountingCost t-if="vals.get('accounting_cost')"
                                    t-out="vals['accounting_cost']"/>
            </t>
        </xpath>

        <!-- BTAE-21 StatementDocumentReference + BTAE-05 ContractDocumentReference
             XSD requires Statement before Contract -->
        <xpath expr="//*[local-name()='BillingReference']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:StatementDocumentReference t-if="vals.get('btae_21_export_declaration')">
                    <cbc:ID t-out="vals['btae_21_export_declaration']"/>
                </cac:StatementDocumentReference>
                <cac:ContractDocumentReference t-if="vals.get('btae_05_contract_value')">
                    <cbc:ID t-if="vals.get('contract_reference')" t-out="vals['contract_reference']"/>
                    <cbc:DocumentDescription t-out="vals['btae_05_contract_value']"/>
                </cac:ContractDocumentReference>
            </t>
        </xpath>

        <!-- BuyerCustomerParty (BTAE-01) + SellerSupplierParty (BTAE-14)
             after AccountingCustomerParty — XSD requires Buyer before Seller -->
        <xpath expr="//*[local-name()='AccountingCustomerParty']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

                <cac:BuyerCustomerParty t-if="vals.get('buyer_customer_party_id')">
                    <cac:Party>
                        <cac:PartyIdentification>
                            <cbc:ID t-out="vals['buyer_customer_party_id']"/>
                        </cac:PartyIdentification>
                    </cac:Party>
                </cac:BuyerCustomerParty>

                <cac:SellerSupplierParty t-if="vals.get('seller_supplier_party_id')">
                    <cac:Party>
                        <cac:PartyIdentification>
                            <cbc:ID t-out="vals['seller_supplier_party_id']"/>
                        </cac:PartyIdentification>
                    </cac:Party>
                </cac:SellerSupplierParty>

            </t>
        </xpath>

        <!-- IBT-011: ProjectReference before AccountingSupplierParty -->
        <xpath expr="//*[local-name()='AccountingSupplierParty']" position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:ProjectReference t-if="vals.get('project_reference')">
                    <cbc:ID t-out="vals['project_reference']"/>
                </cac:ProjectReference>
            </t>
        </xpath>

        <!-- BTAE-04: TaxExchangeRate before TaxTotal
             (PricingExchangeRate is handled by parent via _get_pricing_exchange_rate_vals_list) -->
        <xpath expr="//*[local-name()='TaxTotal']" position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:TaxExchangeRate t-if="vals.get('tax_exchange_rate')">
                    <cbc:SourceCurrencyCode t-out="vals.get('tax_exchange_rate_currency_code')"/>
                    <cbc:TargetCurrencyCode t-out="vals.get('tax_exchange_rate_base_currency_code', 'AED')"/>
                    <cbc:CalculationRate t-out="vals.get('tax_exchange_rate')"/>
                </cac:TaxExchangeRate>
            </t>
        </xpath>

    </template>

    <!-- ════════════════════════════════════════════════════════════════════════
         CreditNoteType — same root-level additions as InvoiceType, plus
         BTAE-03 DiscrepancyResponse
         ════════════════════════════════════════════════════════════════════════ -->
    <template id="pint_ae_CreditNoteType"
              inherit_id="account_edi_ubl_cii.ubl_21_CreditNoteType"
              primary="True">

        <!-- BTAE-02: ProfileExecutionID -->
        <xpath expr="//*[local-name()='ProfileID']" position="after">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:ProfileExecutionID t-if="vals.get('profile_execution_id')"
                                        t-out="vals['profile_execution_id']"/>
            </t>
        </xpath>

        <!-- IssueTime (IBT-168) -->
        <xpath expr="//*[local-name()='IssueDate']" position="after">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:IssueTime t-if="vals.get('issue_time')"
                               t-out="vals['issue_time']"/>
            </t>
        </xpath>

        <!-- IBT-007: TaxPointDate before DocumentCurrencyCode -->
        <xpath expr="//*[local-name()='DocumentCurrencyCode']" position="before">
            <t xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cbc:TaxPointDate t-if="vals.get('tax_point_date')"
                                  t-out="vals['tax_point_date']"/>
            </t>
        </xpath>

        <!-- BTAE-03: DiscrepancyResponse before AccountingSupplierParty -->
        <xpath expr="//*[local-name()='AccountingSupplierParty']" position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:DiscrepancyResponse t-if="vals.get('btae_03_reason')">
                    <cbc:ResponseCode t-out="vals['btae_03_reason']"/>
                </cac:DiscrepancyResponse>
            </t>
        </xpath>

        <!-- BuyerCustomerParty (BTAE-01) + SellerSupplierParty (BTAE-14)
             XSD requires Buyer before Seller -->
        <xpath expr="//*[local-name()='AccountingCustomerParty']" position="after">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

                <cac:BuyerCustomerParty t-if="vals.get('buyer_customer_party_id')">
                    <cac:Party>
                        <cac:PartyIdentification>
                            <cbc:ID t-out="vals['buyer_customer_party_id']"/>
                        </cac:PartyIdentification>
                    </cac:Party>
                </cac:BuyerCustomerParty>

                <cac:SellerSupplierParty t-if="vals.get('seller_supplier_party_id')">
                    <cac:Party>
                        <cac:PartyIdentification>
                            <cbc:ID t-out="vals['seller_supplier_party_id']"/>
                        </cac:PartyIdentification>
                    </cac:Party>
                </cac:SellerSupplierParty>

            </t>
        </xpath>

        <!-- BTAE-04: TaxExchangeRate before TaxTotal -->
        <xpath expr="//*[local-name()='TaxTotal']" position="before">
            <t xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
                <cac:TaxExchangeRate t-if="vals.get('tax_exchange_rate')">
                    <cbc:SourceCurrencyCode t-out="vals.get('tax_exchange_rate_currency_code')"/>
                    <cbc:TargetCurrencyCode t-out="vals.get('tax_exchange_rate_base_currency_code', 'AED')"/>
                    <cbc:CalculationRate t-out="vals.get('tax_exchange_rate')"/>
                </cac:TaxExchangeRate>
            </t>
        </xpath>

    </template>

</odoo>
