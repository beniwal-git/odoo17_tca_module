<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reject wizard form -->
    <record id="tca_inbound_reject_wizard_form" model="ir.ui.view">
        <field name="name">tca.inbound.reject.wizard.form</field>
        <field name="model">tca.inbound.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Inbound Invoice">
                <group>
                    <field name="move_id" readonly="1"/>
                    <field name="reason" widget="text" placeholder="Enter the reason for rejecting this invoice..."/>
                </group>
                <footer>
                    <button name="action_reject" string="Reject Invoice" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Add Accept/Reject buttons to vendor bill form -->
    <record id="view_move_form_tca_inbound_buttons" model="ir.ui.view">
        <field name="name">account.move.form.tca.inbound</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="tca_is_inbound" invisible="1"/>
                <field name="tca_inbound_status" invisible="1"/>
                <button name="action_tca_accept_inbound"
                        string="Accept &amp; Post"
                        type="object"
                        class="btn-success"
                        invisible="not tca_is_inbound or tca_inbound_status != 'pending' or state != 'draft'"
                        data-hotkey="shift+a"
                        />
                <button name="action_tca_reject_inbound"
                        string="Reject"
                        type="object"
                        class="btn-danger"
                        invisible="not tca_is_inbound or tca_inbound_status != 'pending' or state != 'draft'"
                        data-hotkey="shift+r"
                        />
            </xpath>
            <!-- Show inbound status badge -->
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <div invisible="not tca_is_inbound" class="alert alert-info" role="alert">
                    <strong>TCA Peppol Inbound Invoice</strong> —
                    Status: <field name="tca_inbound_status" readonly="1" widget="badge"
                                   decoration-success="tca_inbound_status == 'accepted'"
                                   decoration-danger="tca_inbound_status == 'rejected'"
                                   decoration-warning="tca_inbound_status == 'pending'"/>
                    <field name="tca_reject_reason" invisible="tca_inbound_status != 'rejected'" readonly="1"
                           class="ms-2 text-danger"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
